<%- include('_head', {title: 'Overview'}) %>
  <aside class="sidebar">
    <div class="sidebar-brand">
      <div class="brand-name">⚡ Snapatask</div>
      <div class="brand-sub">CRM v1.0</div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-label">Main</div>
      <a href="/" class="nav-item active">📊 Overview</a>
      <a href="/contractors" class="nav-item">🔧 Contractors <span class="nav-badge"><%= stats.contractors %></span></a>
      <a href="/customers" class="nav-item">👤 Customers <span class="nav-badge"><%= stats.customers %></span></a>
      <div class="nav-label">Actions</div>
      <a href="/outreach" class="nav-item">📨 Outreach Queue <span class="nav-badge"><%= stats.queued %></span></a>
      <a href="/dnc" class="nav-item">🚫 DNC List</a>
      <div class="nav-label">Insights</div>
      <a href="/report" class="nav-item">📈 Reports</a>
    </nav>
    <div class="sidebar-footer">Snapatask CRM<br>Node + PostgreSQL</div>
  </aside>
  <main class="main">
    <div class="topbar">
      <div class="topbar-title">Overview</div>
      <div class="topbar-right"><div class="live-dot"></div><span class="live-text">Live</span></div>
    </div>
    <div class="content">
      <div class="stat-grid">
        <div class="stat-card blue"><span class="stat-icon">🔧</span><div class="stat-num" id="s-contractors"><%= stats.contractors %></div><div class="stat-label">Contractor Leads</div></div>
        <div class="stat-card"><span class="stat-icon">👤</span><div class="stat-num" id="s-customers"><%= stats.customers %></div><div class="stat-label">Customer Leads</div></div>
        <div class="stat-card yellow"><span class="stat-icon">📨</span><div class="stat-num" id="s-queued"><%= stats.queued %></div><div class="stat-label">Queued for Review</div></div>
        <div class="stat-card"><span class="stat-icon">✅</span><div class="stat-num" id="s-sent"><%= stats.sent %></div><div class="stat-label">Messages Sent</div></div>
        <div class="stat-card"><span class="stat-icon">⭐</span><div class="stat-num"><%= stats.high_quality %></div><div class="stat-label">High Quality (7+)</div></div>
        <div class="stat-card"><span class="stat-icon">💬</span><div class="stat-num"><%= stats.replied %></div><div class="stat-label">Replies Received</div></div>
        <div class="stat-card"><span class="stat-icon">🔗</span><div class="stat-num"><%= stats.active_sources %></div><div class="stat-label">Active Sources</div></div>
        <div class="stat-card"><span class="stat-icon">📉</span><div class="stat-num text-mono" style="font-size:22px"><%= stats.avg_score %></div><div class="stat-label">Avg Lead Score</div></div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px">
        <div class="table-wrap">
          <div class="table-header"><span class="table-title">Recent Contractors</span><a href="/contractors" class="btn btn-ghost btn-sm">View All →</a></div>
          <table>
            <thead><tr><th>Company</th><th>Location</th><th>Score</th><th>Status</th></tr></thead>
            <tbody>
              <% if(recent_contractors.length===0){%><tr><td colspan="4"><div class="empty-state"><div class="icon">🔧</div>No contractors yet</div></td></tr><%}%>
              <% recent_contractors.forEach(c=>{%>
              <tr>
                <td class="truncate" style="max-width:150px"><%- (c.company_name||"—").replace(/&amp;/g,"&") %></td>
                <td class="text-muted" style="max-width:100px"><%= (c.location||'').split(',')[0] %></td>
                <td><span class="score-pill <%=c.lead_score>=7?'score-high':c.lead_score>=5?'score-mid':'score-low'%>"><%= c.lead_score %>/10</span></td>
                <td><span class="badge badge-<%=c.contact_status%>"><%= c.contact_status %></span></td>
              </tr>
              <%})%>
            </tbody>
          </table>
        </div>
        <div class="table-wrap">
          <div class="table-header"><span class="table-title">Score Distribution</span><span class="table-count text-mono">contractors</span></div>
          <div style="padding:20px">
            <% score_dist.forEach(s=>{
              const pct=Math.round((s.count/stats.contractors)*100);
              const col=s.lead_score>=7?'#22c55e':s.lead_score>=5?'#eab308':'#64748b';
            %>
            <div style="margin-bottom:14px">
              <div style="display:flex;justify-content:space-between;margin-bottom:5px">
                <span style="font-size:13px;font-family:'DM Mono',monospace">Score <%= s.lead_score %>/10</span>
                <span style="font-size:12px;color:var(--text2)"><%= s.count %> leads (<%= pct %>%)</span>
              </div>
              <div style="height:6px;background:var(--surface2);border-radius:3px;overflow:hidden">
                <div style="height:100%;width:<%=pct%>%;background:<%=col%>;border-radius:3px"></div>
              </div>
            </div>
            <%})%>
            <%if(score_dist.length===0){%><div class="empty-state"><div class="icon">📊</div>No data yet</div><%}%>
          </div>
        </div>
      </div>
      <%if(recent_customers.length>0){%>
      <div class="table-wrap">
        <div class="table-header"><span class="table-title">Recent Customer Leads</span><a href="/customers" class="btn btn-ghost btn-sm">View All →</a></div>
        <table>
          <thead><tr><th>Title</th><th>Location</th><th>Urgency</th><th>Status</th><th>Found</th></tr></thead>
          <tbody>
            <%recent_customers.forEach(c=>{%>
            <tr>
              <td class="truncate" style="max-width:200px"><%= c.post_title||'—' %></td>
              <td class="text-muted"><%= (c.location||'').split(',')[0] %></td>
              <td><span class="badge badge-<%=c.urgency%>"><%= c.urgency %></span></td>
              <td><span class="badge badge-<%=c.contact_status%>"><%= c.contact_status %></span></td>
              <td class="text-muted text-mono" style="font-size:11px"><%= new Date(c.created_at).toLocaleDateString() %></td>
            </tr>
            <%})%>
          </tbody>
        </table>
      </div>
      <%}%>
    </div>
  </main>
  <script>
    setInterval(async()=>{
      try{const d=await fetch('/api/stats').then(r=>r.json());
      document.getElementById('s-contractors').textContent=d.contractors;
      document.getElementById('s-customers').textContent=d.customers;
      document.getElementById('s-queued').textContent=d.queued;
      document.getElementById('s-sent').textContent=d.sent;}catch(e){}
    },30000);
  </script>
</body></html>
