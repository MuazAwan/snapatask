<%- include('_head', {title: 'Customers'}) %>
  <aside class="sidebar">
    <div class="sidebar-brand"><div class="brand-name">⚡ Snapatask</div><div class="brand-sub">CRM v1.0</div></div>
    <nav class="sidebar-nav">
      <div class="nav-label">Main</div>
      <a href="/" class="nav-item">📊 Overview</a>
      <a href="/contractors" class="nav-item">🔧 Contractors</a>
      <a href="/customers" class="nav-item active">👤 Customers</a>
      <div class="nav-label">Actions</div>
      <a href="/outreach" class="nav-item">📨 Outreach Queue</a>
      <a href="/dnc" class="nav-item">🚫 DNC List</a>
      <div class="nav-label">Insights</div>
      <a href="/report" class="nav-item">📈 Reports</a>
    </nav>
    <div class="sidebar-footer">Snapatask CRM</div>
  </aside>
  <main class="main">
    <div class="topbar">
      <div class="topbar-title">Customer Leads</div>
      <div class="topbar-right"><span class="text-muted text-mono" style="font-size:12px"><%= count %> results</span></div>
    </div>
    <div class="content">
      <form class="filters-bar" method="GET" action="/customers">
        <input name="search" placeholder="🔍 Search..." value="<%= filters.search||'' %>" style="min-width:200px">
        <input name="location" placeholder="📍 Location..." value="<%= filters.location||'' %>">
        <select name="status">
          <option value="">All Statuses</option>
          <option <%=filters.status==='new'?'selected':''%> value="new">New</option>
          <option <%=filters.status==='contacted'?'selected':''%> value="contacted">Contacted</option>
          <option <%=filters.status==='interested'?'selected':''%> value="interested">Interested</option>
        </select>
        <select name="urgency">
          <option value="">All Urgency</option>
          <option <%=filters.urgency==='high'?'selected':''%> value="high">🔴 High</option>
          <option <%=filters.urgency==='normal'?'selected':''%> value="normal">Normal</option>
        </select>
        <select name="sort">
          <option value="date">Sort: Date ↓</option>
          <option <%=filters.sort==='score'?'selected':''%> value="score">Sort: Score ↓</option>
        </select>
        <button type="submit" class="btn btn-primary btn-sm">Filter</button>
        <a href="/customers" class="btn btn-ghost btn-sm">Reset</a>
      </form>
      <div class="table-wrap">
        <div class="table-header">
          <span class="table-title">All Customer Leads</span>
          <span class="table-count"><%= count %> records</span>
        </div>
        <%if(leads.length===0){%>
        <div class="empty-state"><div class="icon">👤</div>No customer leads found.</div>
        <%}else{%>
        <div style="overflow-x:auto">
          <table>
            <thead>
              <tr><th>Title</th><th>Location</th><th>Postcode</th><th>Phone</th><th>Urgency</th><th>Score</th><th>Status</th><th>Source</th><th>Found</th><th>Link</th></tr>
            </thead>
            <tbody>
              <%leads.forEach(l=>{%>
              <tr>
                <td style="max-width:200px">
                  <div class="truncate" title="<%=l.post_title%>"><%=l.post_title||'—'%></div>
                  <%if(l.desc_short){%><div class="text-muted" style="font-size:11px;margin-top:2px"><%=l.desc_short.substring(0,80)%>...</div><%}%>
                </td>
                <td class="text-muted"><%=(l.location||'').split(',')[0]%></td>
                <td class="text-mono" style="font-size:11px"><%=l.postcode||'—'%></td>
                <td class="text-mono" style="font-size:12px"><%=l.phone||'—'%></td>
                <td><span class="badge badge-<%=l.urgency%>"><%=l.urgency%></span></td>
                <td><%if(l.lead_score){%><span class="score-pill <%=l.lead_score>=7?'score-high':l.lead_score>=5?'score-mid':'score-low'%>"><%=l.lead_score%>/10</span><%}else{%><span class="text-muted">—</span><%}%></td>
                <td><span class="badge badge-<%=l.contact_status%>"><%=l.contact_status%></span></td>
                <td><span class="badge badge-new" style="font-size:10px"><%=l.source_platform%></span></td>
                <td class="text-muted text-mono" style="font-size:11px"><%=new Date(l.created_at).toLocaleDateString()%></td>
                <td><a href="<%=l.source_url%>" target="_blank" class="btn btn-ghost btn-xs">View →</a></td>
              </tr>
              <%})%>
            </tbody>
          </table>
        </div>
        <%}%>
      </div>
    </div>
  </main>
</body></html>
