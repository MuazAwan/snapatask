<%- include('_head', {title: 'Contractors'}) %>
  <aside class="sidebar">
    <div class="sidebar-brand"><div class="brand-name">⚡ Snapatask</div><div class="brand-sub">CRM v1.0</div></div>
    <nav class="sidebar-nav">
      <div class="nav-label">Main</div>
      <a href="/" class="nav-item">📊 Overview</a>
      <a href="/contractors" class="nav-item active">🔧 Contractors</a>
      <a href="/customers" class="nav-item">👤 Customers</a>
      <div class="nav-label">Actions</div>
      <a href="/outreach" class="nav-item">📨 Outreach Queue</a>
      <a href="/dnc" class="nav-item">🚫 DNC List</a>
      <div class="nav-label">Insights</div>
      <a href="/report" class="nav-item">📈 Reports</a>
    </nav>
    <div class="sidebar-footer">Snapatask CRM</div>
  </aside>
  <main class="main">
    <div class="topbar">
      <div class="topbar-title">Contractor Leads</div>
      <div class="topbar-right"><span class="text-muted text-mono" style="font-size:12px"><%= count %> results</span></div>
    </div>
    <div class="content">
      <form class="filters-bar" method="GET" action="/contractors">
        <input name="search" placeholder="🔍 Search company / services..." value="<%= filters.search||'' %>" style="min-width:200px">
        <input name="location" placeholder="📍 Location..." value="<%= filters.location||'' %>">
        <select name="status">
          <option value="">All Statuses</option>
          <option <%=filters.status==='new'?'selected':''%> value="new">New</option>
          <option <%=filters.status==='contacted'?'selected':''%> value="contacted">Contacted</option>
          <option <%=filters.status==='interested'?'selected':''%> value="interested">Interested</option>
          <option <%=filters.status==='not_interested'?'selected':''%> value="not_interested">Not Interested</option>
          <option <%=filters.status==='registered'?'selected':''%> value="registered">Registered</option>
          <option <%=filters.status==='do_not_contact'?'selected':''%> value="do_not_contact">DNC</option>
        </select>
        <select name="reply">
          <option value="">All Replies</option>
          <option <%=filters.reply==='no_reply'?'selected':''%> value="no_reply">No Reply</option>
          <option <%=filters.reply==='replied'?'selected':''%> value="replied">Replied</option>
          <option <%=filters.reply==='interested'?'selected':''%> value="interested">Interested</option>
          <option <%=filters.reply==='not_interested'?'selected':''%> value="not_interested">Not Interested</option>
        </select>
        <select name="min_score">
          <option value="">Any Score</option>
          <option <%=filters.min_score==='5'?'selected':''%> value="5">Score 5+</option>
          <option <%=filters.min_score==='7'?'selected':''%> value="7">Score 7+</option>
          <option <%=filters.min_score==='9'?'selected':''%> value="9">Score 9+</option>
        </select>
        <select name="sort">
          <option value="score">Sort: Score ↓</option>
          <option <%=filters.sort==='date'?'selected':''%> value="date">Sort: Date ↓</option>
          <option <%=filters.sort==='name'?'selected':''%> value="name">Sort: Name A-Z</option>
        </select>
        <button type="submit" class="btn btn-primary btn-sm">Filter</button>
        <a href="/contractors" class="btn btn-ghost btn-sm">Reset</a>
      </form>
      <div class="table-wrap">
        <div class="table-header">
          <span class="table-title">All Contractors</span>
          <span class="table-count"><%= count %> records</span>
        </div>
        <%if(leads.length===0){%>
        <div class="empty-state"><div class="icon">🔧</div>No contractors found.</div>
        <%}else{%>
        <div style="overflow-x:auto">
          <table>
            <thead>
              <tr><th>Score</th><th>Company</th><th>Location</th><th>Phone</th><th>Services</th><th>Licensed</th><th>Status</th><th>Reply</th><th>Reg.</th><th>Source</th><th>Actions</th></tr>
            </thead>
            <tbody>
              <%leads.forEach(lead=>{%>
              <tr id="row-<%=lead.id%>">
                <td><span class="score-pill <%=lead.lead_score>=7?'score-high':lead.lead_score>=5?'score-mid':'score-low'%>"><%=lead.lead_score%>/10</span></td>
                <td style="max-width:180px"><div class="truncate" title="<%=lead.company_name%>"><%- (lead.company_name||"—").replace(/&amp;/g,"&") %></div></td>
                <td class="text-muted" style="max-width:120px"><div class="truncate"><%=lead.location||'—'%></div></td>
                <td class="text-mono" style="font-size:12px;white-space:nowrap"><%- lead.phone ? lead.phone : '<span class="text-muted">hidden</span>' %></td>
                <td class="text-muted" style="max-width:150px;font-size:12px"><div class="truncate" title="<%=lead.services_short%>"><%=lead.services_short||'—'%></div></td>
                <td style="text-align:center"><%=lead.licence_mentioned?'✅':'—'%></td>
                <td>
                  <select class="select-inline" onchange="updateLead('<%=lead.id%>','contact_status',this.value,'<%=lead.reply_status%>','<%=lead.registration_status%>')">
                    <option <%=lead.contact_status==='new'?'selected':''%> value="new">new</option>
                    <option <%=lead.contact_status==='contacted'?'selected':''%> value="contacted">contacted</option>
                    <option <%=lead.contact_status==='interested'?'selected':''%> value="interested">interested</option>
                    <option <%=lead.contact_status==='not_interested'?'selected':''%> value="not_interested">not interested</option>
                    <option <%=lead.contact_status==='registered'?'selected':''%> value="registered">registered</option>
                    <option <%=lead.contact_status==='do_not_contact'?'selected':''%> value="do_not_contact">DNC</option>
                    <option <%=lead.contact_status==='invalid'?'selected':''%> value="invalid">invalid</option>
                  </select>
                </td>
                <td>
                  <select class="select-inline" onchange="updateLead('<%=lead.id%>','reply_status','<%=lead.contact_status%>',this.value,'<%=lead.registration_status%>')">
                    <option <%=lead.reply_status==='no_reply'?'selected':''%> value="no_reply">no reply</option>
                    <option <%=lead.reply_status==='replied'?'selected':''%> value="replied">replied</option>
                    <option <%=lead.reply_status==='interested'?'selected':''%> value="interested">interested</option>
                    <option <%=lead.reply_status==='not_interested'?'selected':''%> value="not_interested">not interested</option>
                    <option <%=lead.reply_status==='do_not_contact'?'selected':''%> value="do_not_contact">DNC</option>
                  </select>
                </td>
                <td>
                  <select class="select-inline" onchange="updateLead('<%=lead.id%>','registration_status','<%=lead.contact_status%>','<%=lead.reply_status%>',this.value)">
                    <option <%=lead.registration_status==='not_registered'?'selected':''%> value="not_registered">not reg.</option>
                    <option <%=lead.registration_status==='invited'?'selected':''%> value="invited">invited</option>
                    <option <%=lead.registration_status==='registered'?'selected':''%> value="registered">registered</option>
                    <option <%=lead.registration_status==='active'?'selected':''%> value="active">active</option>
                  </select>
                </td>
                <td><span class="badge badge-new" style="font-size:10px"><%=lead.source_platform%></span></td>
                <td><a href="/contractors/<%=lead.id%>" class="btn btn-ghost btn-xs">View →</a></td>
              </tr>
              <%})%>
            </tbody>
          </table>
        </div>
        <%}%>
      </div>
    </div>
  </main>
  <div class="toast" id="toast">✅ Updated</div>
  <script>
    async function updateLead(id,field,cs,rs,reg){
      try{
        await fetch('/contractors/'+id+'/update',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({contact_status:cs,reply_status:rs,registration_status:reg})});
        const t=document.getElementById('toast');t.style.display='block';setTimeout(()=>t.style.display='none',2000);
      }catch(e){alert('Error: '+e.message);}
    }
  </script>
</body></html>
